<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Películas</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@0.9.4/css/bulma.min.css">
    <meta name="viewport" content="width=device-width, initial-scale=1">
</head>
<body>
    <header>
        <nav class="navbar is-dark" role="navigation" aria-label="main navigation">
            <div class="navbar-brand">
                <% if (isLoggedIn == true)  { %>
                    <span class="navbar-item">
                        <%= username %>
                    </span>
                    <% for(let permiso of privilegios) { %>
                        <% if (permiso.nombre == 'peliculas_ver') { %>
                            <a class="navbar-item" href="/peliculas">
                                Películas
                            </a>
                        <% } %>
                        <% if (permiso.nombre == 'peliculas_agregar') { %>
                            <a class="navbar-item" href="/peliculas/add">
                                Registrar
                            </a>
                        <% } %>
                    <% } %>
                <% } %>
            </div>

            <div class="navbar-end">
                <div class="navbar-item">
                    <div class="buttons">
                        <% if (isLoggedIn == false)  { %>
                        <a class="button is-primary" href="/users/add">
                            <strong>Registrar (es gratis)</strong>
                        </a>
                        <a class="button is-light" href="/users/login">
                            Entrar
                        </a>
                        <% } else { %>
                        <a class="button is-danger" href="/users/logout">
                            Salir
                        </a>
                        <% } %>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main>
        <section class="section">
            <div class="container">